<Application x:Class="CodePrint.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CodePrint.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
            <converters:MmToPixelConverter x:Key="MmToPixel"/>
            <converters:ColorStringToBrushConverter x:Key="ColorToBrush"/>
            <converters:ElementTypeToIconConverter x:Key="ElementTypeToIcon"/>
            <converters:LabelThumbnailConverter x:Key="LabelThumbnail"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
