<UserControl x:Class="CodePrint.Views.Panels.LayerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
            Effect="{StaticResource CardShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#F0F0F0" CornerRadius="4,4,0,0"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <Grid Margin="8,0">
                    <TextBlock Text="📑 图层管理" FontSize="12" FontWeight="SemiBold" Foreground="#333"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="24" Height="24" FontSize="11" Cursor="Hand"
                            Background="Transparent" BorderThickness="0"
                            Command="{Binding DataContext.ToggleLayerPanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </Grid>
            </Border>

            <!-- Layer List -->
            <ListBox Grid.Row="1" x:Name="LayerList"
                     ItemsSource="{Binding CurrentDocument.Elements}"
                     SelectedItem="{Binding SelectedElement}"
                     Background="Transparent" BorderThickness="0"
                     Margin="4">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="32" Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Layer Icon -->
                            <TextBlock Grid.Column="0" Text="{Binding Type, Converter={StaticResource ElementTypeToIcon}}"
                                       FontSize="14" VerticalAlignment="Center" Margin="4,0"/>

                            <!-- Layer Name -->
                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                       FontSize="11" VerticalAlignment="Center" Margin="4,0"
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- Lock indicator -->
                            <TextBlock Grid.Column="2" Text="🔒" FontSize="10"
                                       VerticalAlignment="Center" Margin="2,0"
                                       Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}"/>

                            <!-- Visibility indicator -->
                            <TextBlock Grid.Column="3" FontSize="10"
                                       VerticalAlignment="Center" Margin="2,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="👁"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                <Setter Property="Text" Value="—"/>
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>
