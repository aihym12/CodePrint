<UserControl x:Class="CodePrint.Views.Panels.PhotoPrintView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CodePrint.ViewModels"
             Background="White" AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver">

    <UserControl.DataContext>
        <vm:PhotoPrintViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Image Source="/app.ico" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="小茗标签" Foreground="White" FontSize="16" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text=" — 照片打印" Foreground="#FFFFFFCC" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Content="← 返回" Style="{StaticResource TitleBarButton}" FontSize="13"
                        Margin="0,0,16,0" Command="{Binding GoBackCommand}"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Photo List -->
            <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Add photos button -->
                    <StackPanel Grid.Row="0" Margin="12">
                        <Button Content="➕ 添加图片" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Click="AddPhotos_Click"/>
                    </StackPanel>

                    <!-- Photo list -->
                    <ListBox Grid.Row="1" x:Name="PhotoList" ItemsSource="{Binding Photos}"
                             SelectedItem="{Binding SelectedPhoto}" BorderThickness="0" Background="Transparent"
                             Margin="8,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                                        Padding="8" Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🖼" FontSize="24" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                            <TextBlock Text="{Binding FileName}" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                            <TextBlock FontSize="10" Foreground="#999">
                                                <Run Text="份数:"/>
                                                <Run Text="{Binding Copies}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBox Grid.Column="2" Text="{Binding Copies, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="35" FontSize="11" Padding="2" VerticalContentAlignment="Center"
                                                 VerticalAlignment="Center" TextAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Bottom actions -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12" HorizontalAlignment="Center">
                        <Button Content="🗑 移除" Style="{StaticResource SmallActionButton}" Command="{Binding RemovePhotoCommand}"/>
                        <Button Content="清空" Style="{StaticResource SmallActionButton}" Command="{Binding ClearPhotosCommand}" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Center: Preview -->
            <Grid Grid.Column="1" Background="#F0F0F0">
                <!-- Empty state -->
                <Border Background="White" CornerRadius="8" Margin="40" Effect="{StaticResource CardShadow}"
                        Visibility="{Binding SelectedPhoto, Converter={StaticResource NullToVisibility}, ConverterParameter=Invert}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🖼" FontSize="64" HorizontalAlignment="Center"/>
                        <TextBlock Text="点击添加图片或将图片文件拖曳至此处" FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,16,0,4"/>
                        <TextBlock Text="支持 JPG、PNG、BMP、GIF、TIFF" FontSize="11" Foreground="#999" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Photo preview -->
                <Border Background="White" CornerRadius="8" Margin="40" Effect="{StaticResource CardShadow}"
                        Visibility="{Binding SelectedPhoto, Converter={StaticResource NullToVisibility}}">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🖼" FontSize="80" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedPhoto.FileName}" FontSize="12" Foreground="#666"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                            <TextBlock Text="图片预览区域" FontSize="13" Foreground="#999"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: Adjustment Panel -->
            <Border Grid.Column="2" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel IsEnabled="{Binding SelectedPhoto, Converter={StaticResource NullToVisibility}}">
                        <TextBlock Text="图片调整" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,16"/>

                        <!-- Rotation -->
                        <TextBlock Text="旋转" FontSize="12" Foreground="#666" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="↺ 逆时针" Style="{StaticResource SmallActionButton}" Command="{Binding RotateCounterClockwiseCommand}"/>
                            <Button Content="↻ 顺时针" Style="{StaticResource SmallActionButton}" Command="{Binding RotateClockwiseCommand}" Margin="8,0,0,0"/>
                        </StackPanel>

                        <!-- Scale Mode -->
                        <TextBlock Text="缩放模式" FontSize="12" Foreground="#666" Margin="0,0,0,6"/>
                        <StackPanel Margin="0,0,0,16">
                            <RadioButton Content="等比适应" IsChecked="True" FontSize="12" Margin="0,0,0,4" Checked="FitMode_Checked"/>
                            <RadioButton Content="填满" FontSize="12" Margin="0,0,0,4" Checked="FillMode_Checked"/>
                            <RadioButton Content="拉伸" FontSize="12" Checked="StretchMode_Checked"/>
                        </StackPanel>

                        <!-- Brightness -->
                        <TextBlock Text="亮度" FontSize="12" Foreground="#666" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0.5" Maximum="1.5" Value="{Binding SelectedPhoto.Brightness}"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedPhoto.Brightness, StringFormat=F1}"
                                       FontSize="11" Foreground="#666" VerticalAlignment="Center" TextAlignment="Center"/>
                        </Grid>

                        <!-- Contrast -->
                        <TextBlock Text="对比度" FontSize="12" Foreground="#666" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0.5" Maximum="1.5" Value="{Binding SelectedPhoto.Contrast}"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedPhoto.Contrast, StringFormat=F1}"
                                       FontSize="11" Foreground="#666" VerticalAlignment="Center" TextAlignment="Center"/>
                        </Grid>

                        <Separator Margin="0,4,0,16"/>

                        <!-- Print DPI -->
                        <TextBlock Text="打印 DPI" FontSize="12" Foreground="#666" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <ComboBox ItemsSource="{Binding DpiOptions}" SelectedItem="{Binding PrintDpi}"
                                      IsEditable="True" Text="{Binding PrintDpi, UpdateSourceTrigger=PropertyChanged}"
                                      Width="90" FontSize="12" Padding="4,2"/>
                            <TextBlock Text=" DPI" VerticalAlignment="Center" FontSize="11" Foreground="#999" Margin="4,0,0,0"/>
                        </StackPanel>

                        <!-- Print -->
                        <Button Content="🖨 打印" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Command="{Binding PrintCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="11" Foreground="#666"/>
                <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="11" Foreground="#666">
                    <Run Text="图片数量: "/>
                    <Run Text="{Binding Photos.Count, Mode=OneWay}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>
