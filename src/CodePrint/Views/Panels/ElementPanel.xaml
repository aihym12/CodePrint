<UserControl x:Class="CodePrint.Views.Panels.ElementPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="8">
                <TextBlock Text="元素" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,4,0,8"/>

                <Button Style="{StaticResource ElementPanelButton}" Content="📝 文本"
                        Tag="Text"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="||| 条码"
                        Tag="Barcode"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="⊞ 二维码"
                        Tag="QrCode"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="🔗 关联码"
                        Tag="LinkedQrCode"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="🖼 图片"
                        Tag="Image"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="★ 图标"
                        Tag="Icon"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="━ 线条"
                        Tag="Line"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="▭ 矩形"
                        Tag="Rectangle"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="📅 日期"
                        Tag="Date"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="▦ 表格"
                        Tag="Table"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="📄 PDF"
                        Tag="Pdf"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="⚠ 警示语"
                        Tag="Warning"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>
                <Button Style="{StaticResource ElementPanelButton}" Content="💧 水印"
                        Tag="Watermark"
                        MouseDoubleClick="ElementButton_MouseDoubleClick"
                        PreviewMouseLeftButtonDown="ElementButton_PreviewMouseLeftButtonDown"
                        PreviewMouseMove="ElementButton_PreviewMouseMove"
                        PreviewMouseRightButtonUp="ElementButton_PreviewMouseRightButtonUp"/>

                <Separator Margin="0,8"/>

                <Button Style="{StaticResource ElementPanelButton}" Content="📷 图片转文字"
                        Click="ImportImageAsText_Click"
                        ToolTip="导入图片并识别文字为可编辑文本"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
