<UserControl x:Class="CodePrint.Views.Panels.PdfCropView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CodePrint.ViewModels"
             Background="White" AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver">

    <UserControl.DataContext>
        <vm:PdfCropViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="🍅" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="番茄标签" Foreground="White" FontSize="16" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text=" — PDF剪裁与打印" Foreground="#FFFFFFCC" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Content="← 返回" Style="{StaticResource TitleBarButton}" FontSize="13"
                        Margin="0,0,16,0" Command="{Binding GoBackCommand}"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Settings -->
            <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                        <!-- Select PDF Button -->
                        <Button Content="📁 选择PDF文件" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Margin="0,0,0,20" Click="SelectPdf_Click"/>

                        <!-- Processing Mode Selection -->
                        <TextBlock Text="处理模式" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>

                        <!-- Mode 1: Page Crop -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <RadioButton x:Name="PageCropRadio" GroupName="ProcessingMode" IsChecked="True"
                                             Checked="PageCropMode_Checked" Margin="0,0,0,4">
                                    <TextBlock Text="● 页面裁剪" FontSize="13" FontWeight="SemiBold"/>
                                </RadioButton>
                                <TextBlock Text="裁剪文档页面大小" Foreground="#666" FontSize="11" Margin="20,0,0,4"/>

                                <!-- Auto / Manual sub-options -->
                                <StackPanel Margin="20,4,0,0"
                                            Visibility="{Binding ElementName=PageCropRadio, Path=IsChecked, Converter={StaticResource BoolToVisibility}}">
                                    <RadioButton x:Name="AutoCropRadio" GroupName="CropMode" Content="自动裁剪" IsChecked="True"
                                                 FontSize="12" Margin="0,0,0,4" Checked="AutoCrop_Checked"/>
                                    <TextBlock Text="自动检测内容边界并去除空白" Foreground="#999" FontSize="10" Margin="18,0,0,4"/>

                                    <RadioButton x:Name="ManualCropRadio" GroupName="CropMode" Content="手动裁剪"
                                                 FontSize="12" Margin="0,4,0,4" Checked="ManualCrop_Checked"/>
                                    <TextBlock Text="拖拽裁剪框选择区域" Foreground="#999" FontSize="10" Margin="18,0,0,0"/>

                                    <!-- Manual crop fields (visible when ManualCropRadio is checked) -->
                                    <StackPanel Margin="18,8,0,0"
                                                Visibility="{Binding ElementName=ManualCropRadio, Path=IsChecked, Converter={StaticResource BoolToVisibility}}">
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="x:" VerticalAlignment="Center" FontSize="11"/>
                                            <TextBox Grid.Column="1" Text="{Binding CropX}" FontSize="11" Padding="4,2" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="2" Text="y:" VerticalAlignment="Center" FontSize="11"/>
                                            <TextBox Grid.Column="3" Text="{Binding CropY}" FontSize="11" Padding="4,2"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="宽:" VerticalAlignment="Center" FontSize="11"/>
                                            <TextBox Grid.Column="1" Text="{Binding CropWidth}" FontSize="11" Padding="4,2" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="2" Text="高:" VerticalAlignment="Center" FontSize="11"/>
                                            <TextBox Grid.Column="3" Text="{Binding CropHeight}" FontSize="11" Padding="4,2"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Mode 2: Label Split -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <RadioButton x:Name="LabelSplitRadio" GroupName="ProcessingMode"
                                             Checked="LabelSplitMode_Checked" Margin="0,0,0,4">
                                    <TextBlock Text="○ 标签分割" FontSize="13" FontWeight="SemiBold"/>
                                </RadioButton>
                                <TextBlock Text="将一个页面分割成多个标签" Foreground="#666" FontSize="11" Margin="20,0,0,0"/>

                                <!-- Split settings -->
                                <StackPanel Margin="20,8,0,0"
                                            Visibility="{Binding ElementName=LabelSplitRadio, Path=IsChecked, Converter={StaticResource BoolToVisibility}}">
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="行数：" VerticalAlignment="Center" FontSize="11"/>
                                        <TextBox Grid.Column="1" Text="{Binding SplitRows}" FontSize="11" Padding="4,2"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="列数：" VerticalAlignment="Center" FontSize="11"/>
                                        <TextBox Grid.Column="1" Text="{Binding SplitColumns}" FontSize="11" Padding="4,2"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="25"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="间距：" VerticalAlignment="Center" FontSize="11"/>
                                        <TextBox Grid.Column="1" Text="{Binding SplitGapMm}" FontSize="11" Padding="4,2"/>
                                        <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" FontSize="10" Foreground="#999" Margin="4,0,0,0"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="25"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="边距：" VerticalAlignment="Center" FontSize="11"/>
                                        <TextBox Grid.Column="1" Text="{Binding SplitMarginMm}" FontSize="11" Padding="4,2"/>
                                        <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" FontSize="10" Foreground="#999" Margin="4,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Mode 3: None (direct print) -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <RadioButton x:Name="NoneRadio" GroupName="ProcessingMode"
                                             Checked="NoneMode_Checked" Margin="0,0,0,4">
                                    <TextBlock Text="○ 无" FontSize="13" FontWeight="SemiBold"/>
                                </RadioButton>
                                <TextBlock Text="直接打印，不做任何裁剪处理" Foreground="#666" FontSize="11" Margin="20,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Next Step -->
                        <Button Content="下一步 →" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Command="{Binding GoToNextStepCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Panel: Preview Area -->
            <Grid Grid.Column="1" Background="#F0F0F0">
                <!-- Empty state -->
                <Border Background="White" CornerRadius="8" Margin="40" Effect="{StaticResource CardShadow}"
                        Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📄" FontSize="64" HorizontalAlignment="Center"/>
                        <TextBlock Text="点击或将PDF文件直接拖曳" FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,16,0,4"/>
                        <TextBlock Text="进该区域即可上传" FontSize="14" Foreground="#666" HorizontalAlignment="Center"/>
                        <TextBlock Text="支持 .pdf 格式，文件 ≤ 50MB" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Loaded state -->
                <Border Background="White" CornerRadius="8" Margin="40" Effect="{StaticResource CardShadow}"
                        Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PdfFilePath}" FontSize="12" Foreground="#666"
                                       HorizontalAlignment="Center" Margin="0,12,0,0" TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                            <TextBlock Text="PDF预览区域" FontSize="13" Foreground="#999"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="11" Foreground="#666" Margin="16,0"/>
        </Border>
    </Grid>
</UserControl>
