<UserControl x:Class="CodePrint.Views.Panels.PdfCropView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CodePrint.ViewModels"
             Background="White" AllowDrop="True" Drop="OnFileDrop" DragOver="OnDragOver">

    <UserControl.DataContext>
        <vm:PdfCropViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Paper size radio button style -->
        <Style x:Key="PaperSizeRadio" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Density toggle button style -->
        <Style x:Key="DensityToggle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="4" Padding="12,4" Cursor="Hand" MinWidth="40">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF6D00"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                <Setter Property="Foreground" Value="#FF6D00"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFF8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Image Source="/app.ico" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="小茗标签" Foreground="White" FontSize="16" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text=" — PDF剪裁与打印" Foreground="#FFFFFFCC" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Content="← 返回" Style="{StaticResource TitleBarButton}" FontSize="13"
                        Margin="0,0,16,0" Command="{Binding GoBackCommand}"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- STEP 1: File Selection & Processing Mode           -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsNextStepVisible, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Settings -->
            <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                        <Button Content="📁 选择PDF文件" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Margin="0,0,0,20" Click="SelectPdf_Click"/>

                        <TextBlock Text="处理模式" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>

                        <!-- Mode 1: Page Crop -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <RadioButton x:Name="PageCropRadio" GroupName="ProcessingMode"
                                             Checked="PageCropMode_Checked" Margin="0,0,0,4">
                                    <TextBlock Text="● 页面裁剪" FontSize="13" FontWeight="SemiBold"/>
                                </RadioButton>
                                <TextBlock Text="裁剪文档页面大小" Foreground="#666" FontSize="11" Margin="20,0,0,4"/>
                            </StackPanel>
                        </Border>

                        <!-- Mode 2: Label Split -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <RadioButton x:Name="LabelSplitRadio" GroupName="ProcessingMode"
                                             Checked="LabelSplitMode_Checked" Margin="0,0,0,4">
                                    <TextBlock Text="○ 标签分割" FontSize="13" FontWeight="SemiBold"/>
                                </RadioButton>
                                <TextBlock Text="将一个页面分割成多个标签" Foreground="#666" FontSize="11" Margin="20,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Mode 3: None (direct print) -->
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <RadioButton x:Name="NoneRadio" GroupName="ProcessingMode"
                                             Checked="NoneMode_Checked" Margin="0,0,0,4">
                                    <TextBlock Text="○ 无" FontSize="13" FontWeight="SemiBold"/>
                                </RadioButton>
                                <TextBlock Text="直接打印，不做任何裁剪处理" Foreground="#666" FontSize="11" Margin="20,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <Button Content="下一步 →" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch"
                                Command="{Binding GoToNextStepCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Panel: Preview Area (Step 1) -->
            <Grid Grid.Column="1" Background="#E0E0E0">
                <!-- Empty state -->
                <Border Background="White" CornerRadius="8" Margin="40" Effect="{StaticResource CardShadow}"
                        Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="📄" FontSize="64" HorizontalAlignment="Center"/>
                        <TextBlock Text="点击或将PDF文件直接拖曳" FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,16,0,4"/>
                        <TextBlock Text="进该区域即可上传" FontSize="14" Foreground="#666" HorizontalAlignment="Center"/>
                        <TextBlock Text="支持 .pdf 格式，文件 ≤ 50MB" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Loaded state with rendered preview -->
                <Grid Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisibility}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly" Margin="20">
                        <Border Background="White" Effect="{StaticResource CardShadow}"
                                BorderBrush="#C0C0C0" BorderThickness="1">
                            <Image Source="{Binding PreviewImage}" Stretch="None"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                    </Viewbox>

                    <!-- Page navigation -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Button Content="◀ 上一页" Style="{StaticResource ToolbarButton}" Padding="8,4"
                                Command="{Binding PreviousPageCommand}"/>
                        <TextBlock Text="{Binding PageInfoText}" VerticalAlignment="Center" Margin="12,0"
                                   FontSize="12" Foreground="#666"/>
                        <Button Content="下一页 ▶" Style="{StaticResource ToolbarButton}" Padding="8,4"
                                Command="{Binding NextPageCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- STEP 2: Paper Size, Density & Print                -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsNextStepVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Print Settings -->
            <Border Grid.Column="0" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                    <StackPanel>
                        <!-- Paper size selection -->
                        <TextBlock Text="设置纸张尺寸" FontSize="14" FontWeight="SemiBold" Foreground="#4A90D9" Margin="0,0,0,16"/>

                        <RadioButton Style="{StaticResource PaperSizeRadio}" GroupName="PaperSize"
                                     Tag="0" Checked="PaperSize_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="100*100mm" FontSize="13"/>
                                <TextBlock Text=" ✏" FontSize="11" Foreground="#999" Margin="4,0,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource PaperSizeRadio}" GroupName="PaperSize"
                                     Tag="1" Checked="PaperSize_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="100*150mm" FontSize="13"/>
                                <TextBlock Text=" ✏" FontSize="11" Foreground="#999" Margin="4,0,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource PaperSizeRadio}" GroupName="PaperSize"
                                     Tag="2" Checked="PaperSize_Checked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="58*40mm" FontSize="13"/>
                                <TextBlock Text=" ✏" FontSize="11" Foreground="#999" Margin="4,0,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource PaperSizeRadio}" GroupName="PaperSize"
                                     Tag="3" Checked="PaperSize_Checked">
                            <TextBlock Text="自定义大小" FontSize="13"/>
                        </RadioButton>

                        <!-- Custom size inputs -->
                        <StackPanel Margin="24,0,0,8"
                                    Visibility="{Binding IsCustomSize, Converter={StaticResource BoolToVisibility}}">
                            <Grid Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="宽:" VerticalAlignment="Center" FontSize="11"/>
                                <TextBox Grid.Column="1" Text="{Binding CustomWidthMm, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="4,2"/>
                                <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" FontSize="10" Foreground="#999" Margin="4,0,0,0"/>
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="高:" VerticalAlignment="Center" FontSize="11"/>
                                <TextBox Grid.Column="1" Text="{Binding CustomHeightMm, UpdateSourceTrigger=PropertyChanged}" FontSize="11" Padding="4,2"/>
                                <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" FontSize="10" Foreground="#999" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- Print layout -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="打印排数" VerticalAlignment="Center" FontSize="13" Margin="0,0,12,0"/>
                            <ComboBox Grid.Column="1" SelectedIndex="{Binding PrintLayoutIndex}" FontSize="12" Padding="6,4">
                                <ComboBoxItem Content="单排(一行一个标签)"/>
                                <ComboBoxItem Content="双排(一行两个标签)"/>
                                <ComboBoxItem Content="三排(一行三个标签)"/>
                            </ComboBox>
                        </Grid>

                        <!-- Apply to all pages -->
                        <CheckBox IsChecked="{Binding ApplyCropToAllPages}" Margin="0,16,0,0" FontSize="12">
                            <TextBlock Text="当前裁剪范围应用到所有页面" Foreground="#4A90D9"/>
                        </CheckBox>

                        <!-- Image density -->
                        <TextBlock Text="画质浓度" FontSize="13" Margin="0,20,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Style="{StaticResource DensityToggle}" GroupName="Density"
                                         Content="自适应" Tag="Auto" Checked="Density_Checked"/>
                            <RadioButton Style="{StaticResource DensityToggle}" GroupName="Density"
                                         Content="淡" Tag="Light" Checked="Density_Checked"/>
                            <RadioButton Style="{StaticResource DensityToggle}" GroupName="Density"
                                         Content="中" Tag="Medium" Checked="Density_Checked"/>
                            <RadioButton Style="{StaticResource DensityToggle}" GroupName="Density"
                                         Content="浓" Tag="Dark" Checked="Density_Checked"/>
                            <RadioButton Style="{StaticResource DensityToggle}" GroupName="Density"
                                         Content="自定义" Tag="Custom" Checked="Density_Checked"/>
                        </StackPanel>
                        <!-- Custom DPI input -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                    Visibility="{Binding IsCustomDensity, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="DPI：" VerticalAlignment="Center" FontSize="12"/>
                            <TextBox Text="{Binding CustomDpi, UpdateSourceTrigger=PropertyChanged}" Width="80" FontSize="12" Padding="4,2"/>
                            <TextBlock Text=" (72~1200)" VerticalAlignment="Center" FontSize="11" Foreground="#999"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DensityHintText}" FontSize="11" Foreground="#888"
                                   Margin="0,4,0,0"/>

                        <!-- Spacer to push buttons to bottom -->
                        <Grid Height="40"/>

                        <!-- Step 2 bottom buttons -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="上一步" HorizontalAlignment="Stretch"
                                    FontSize="13" Padding="0,8" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                    Cursor="Hand" Command="{Binding GoToPreviousStepCommand}"/>
                            <Button Grid.Column="2" Content="打 印" Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Stretch" Padding="0,8"
                                    Command="{Binding PrintCommand}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Panel: Preview (Step 2) -->
            <Grid Grid.Column="1" Background="#E0E0E0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- PDF preview image -->
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly" Margin="30">
                    <Border Background="White" Effect="{StaticResource CardShadow}"
                            BorderBrush="#C0C0C0" BorderThickness="1">
                        <Image Source="{Binding PreviewImage}" Stretch="None"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </Viewbox>

                <!-- Page navigation bar -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Button Content="◀ 上一页" Style="{StaticResource ToolbarButton}" Padding="10,6"
                            Command="{Binding PreviousPageCommand}"/>
                    <TextBlock Text="{Binding PageInfoText}" VerticalAlignment="Center" Margin="16,0"
                               FontSize="13" Foreground="#666"/>
                    <Button Content="下一页 ▶" Style="{StaticResource ToolbarButton}" Padding="10,6"
                            Command="{Binding NextPageCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="11" Foreground="#666" Margin="16,0"/>
        </Border>
    </Grid>
</UserControl>
