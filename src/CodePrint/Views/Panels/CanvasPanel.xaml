<UserControl x:Class="CodePrint.Views.Panels.CanvasPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#E8E8E8">
    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" PanningMode="Both">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <!-- Label Design Area -->
                <Border x:Name="LabelBorder" Margin="20" Background="White"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        Effect="{StaticResource LabelShadow}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                    </Border.LayoutTransform>
                    <Canvas x:Name="DesignCanvas" Width="189" Height="113"
                            Background="{Binding CurrentDocument.BackgroundColor, Converter={StaticResource ColorToBrush}}"
                            ClipToBounds="True"
                            AllowDrop="True"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                            MouseMove="Canvas_MouseMove"
                            MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                            Drop="Canvas_Drop"
                            DragOver="Canvas_DragOver">

                        <!-- Context Menu -->
                        <Canvas.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="复制" Command="{Binding CopySelectedCommand}" InputGestureText="Ctrl+C"/>
                                <MenuItem Header="粘贴" Command="{Binding PasteCommand}" InputGestureText="Ctrl+V"/>
                                <MenuItem Header="剪切" Command="{Binding CutSelectedCommand}" InputGestureText="Ctrl+X"/>
                                <MenuItem Header="删除" Command="{Binding DeleteSelectedCommand}" InputGestureText="Delete"/>
                                <Separator/>
                                <MenuItem Header="置于顶层" Command="{Binding BringToFrontCommand}" InputGestureText="Ctrl+Shift+]"/>
                                <MenuItem Header="上移一层" Command="{Binding MoveLayerUpCommand}" InputGestureText="Ctrl+]"/>
                                <MenuItem Header="下移一层" Command="{Binding MoveLayerDownCommand}" InputGestureText="Ctrl+["/>
                                <MenuItem Header="置于底层" Command="{Binding SendToBackCommand}" InputGestureText="Ctrl+Shift+["/>
                                <Separator/>
                                <MenuItem Header="锁定元素" Command="{Binding ToggleLockCommand}"/>
                                <MenuItem Header="复制并粘贴" Command="{Binding DuplicateCommand}" InputGestureText="Ctrl+D"/>
                            </ContextMenu>
                        </Canvas.ContextMenu>

                        <Grid Width="{Binding ActualWidth, ElementName=DesignCanvas}"
                              Height="{Binding ActualHeight, ElementName=DesignCanvas}"
                              IsHitTestVisible="False">
                            <TextBlock x:Name="PlaceholderText" Text="双击此处开始设计"
                                       Foreground="#CCC" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Canvas>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Zoom indicator -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12"
                Background="#E0E0E0" CornerRadius="4" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="−" Style="{StaticResource SmallButton}" Command="{Binding ZoomOutCommand}"/>
                <TextBlock Text="{Binding ZoomPercentage}" VerticalAlignment="Center" Margin="8,0" FontSize="12" MinWidth="40" TextAlignment="Center"/>
                <Button Content="+" Style="{StaticResource SmallButton}" Command="{Binding ZoomInCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
