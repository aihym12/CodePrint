<UserControl x:Class="CodePrint.Views.Panels.CanvasPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#E8E8E8">
    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" PanningMode="Both">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
                <!-- Label Design Area -->
                <Border x:Name="LabelBorder" Margin="20" Background="White"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        Effect="{StaticResource LabelShadow}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}"/>
                    </Border.RenderTransform>
                    <Canvas x:Name="DesignCanvas" Width="189" Height="113"
                            Background="{Binding CurrentDocument.BackgroundColor, Converter={StaticResource ColorToBrush}}"
                            ClipToBounds="True">
                        <TextBlock Canvas.Left="10" Canvas.Top="10" Text="双击此处开始设计"
                                   Foreground="#CCC" FontSize="14" IsHitTestVisible="False"/>
                    </Canvas>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Zoom indicator -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12"
                Background="#E0E0E0" CornerRadius="4" Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="−" Style="{StaticResource SmallButton}" Command="{Binding ZoomOutCommand}"/>
                <TextBlock Text="{Binding ZoomPercentage}" VerticalAlignment="Center" Margin="8,0" FontSize="12" MinWidth="40" TextAlignment="Center"/>
                <Button Content="+" Style="{StaticResource SmallButton}" Command="{Binding ZoomInCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
