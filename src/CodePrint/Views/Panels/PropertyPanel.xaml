<UserControl x:Class="CodePrint.Views.Panels.PropertyPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:CodePrint.Converters">
    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <TextBlock Text="属性" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,4,0,12"/>

                <!-- No selection message -->
                <TextBlock Text="选中元素后显示属性" FontSize="11" Foreground="#AAA" FontStyle="Italic"
                           Visibility="{Binding SelectedElement, Converter={StaticResource NullToVis}, ConverterParameter=Invert}"/>

                <!-- Properties shown when an element is selected -->
                <StackPanel Visibility="{Binding SelectedElement, Converter={StaticResource NullToVis}}">
                    <!-- Element Name & Type -->
                    <TextBlock Text="{Binding SelectedElement.Name}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>

                    <!-- Position & Size -->
                    <TextBlock Text="位置与尺寸" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,4">
                            <TextBlock Text="x (mm)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding SelectedElement.X, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,4">
                            <TextBlock Text="y (mm)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding SelectedElement.Y, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,4,4">
                            <TextBlock Text="w (mm)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding SelectedElement.Width, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,0,4">
                            <TextBlock Text="h (mm)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding SelectedElement.Height, StringFormat={}{0:F2}, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="锁定宽高比" Margin="0,4,0,8" FontSize="11"/>
                    <Separator Margin="0,4"/>

                    <!-- Common Properties -->
                    <TextBlock Text="通用属性" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,8,0,8"/>

                    <StackPanel Margin="0,0,0,4">
                        <TextBlock Text="旋转角度" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0" Maximum="360" Value="{Binding SelectedElement.Rotation}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource PropertyTextBox}"
                                     Text="{Binding SelectedElement.Rotation, StringFormat={}{0:F0}°, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,4">
                        <TextBlock Text="透明度" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0" Maximum="1" Value="{Binding SelectedElement.Opacity}" SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource PropertyTextBox}"
                                     Text="{Binding SelectedElement.Opacity, StringFormat={}{0:P0}, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,4">
                        <TextBlock Text="图层顺序" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="⬆ 上移" Style="{StaticResource SmallActionButton}" Command="{Binding DataContext.MoveLayerUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Button Content="⬇ 下移" Style="{StaticResource SmallActionButton}" Margin="4,0,0,0" Command="{Binding DataContext.MoveLayerDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Button Content="⤴ 顶层" Style="{StaticResource SmallActionButton}" Margin="4,0,0,0" Command="{Binding DataContext.BringToFrontCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Button Content="⤵ 底层" Style="{StaticResource SmallActionButton}" Margin="4,0,0,0" Command="{Binding DataContext.SendToBackCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </StackPanel>
                    </StackPanel>

                    <CheckBox Content="🔒 锁定元素" IsChecked="{Binding SelectedElement.IsLocked}" FontSize="11" Margin="0,4,0,4"/>

                    <Separator Margin="0,8"/>

                    <!-- Element-Specific Properties (displayed by code-behind) -->
                    <TextBlock Text="元素属性" FontSize="12" FontWeight="SemiBold" Foreground="#555" Margin="0,8,0,8"/>
                    <StackPanel x:Name="ElementPropertiesPanel"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
