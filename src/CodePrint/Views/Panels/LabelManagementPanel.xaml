<UserControl x:Class="CodePrint.Views.Panels.LabelManagementPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CodePrint.ViewModels">
    <UserControl.DataContext>
        <vm:LabelManagementViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search & Actions Bar -->
        <Border Grid.Row="0" Padding="12,8" Background="#F5F5F5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="6,4" FontSize="12" Margin="0,0,8,0">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="  🔍 搜索标签..." Foreground="#BBB" FontSize="12" Margin="4,0"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <Button Grid.Column="1" Content="+ 新建标签" Padding="8,4" FontSize="11"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                        Command="{Binding CreateLabelCommand}"/>
                <Button Grid.Column="2" Content="多选" Padding="8,4" FontSize="11"
                        Command="{Binding ToggleMultiSelectCommand}"/>
            </Grid>
        </Border>

        <!-- Folder list -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="8,4">
                    <ItemsControl ItemsSource="{Binding Folders}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}" Margin="2" Padding="8,4" FontSize="11"
                                        Cursor="Hand" Background="#F0F0F0" BorderThickness="1" BorderBrush="#DDD"
                                        Command="{Binding DataContext.SelectFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ 新建文件夹" Margin="4,2" Padding="6,4" FontSize="10"
                            Background="Transparent" BorderThickness="1" BorderBrush="#CCC" Cursor="Hand"
                            Command="{Binding CreateFolderCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Label Cards Grid -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredLabels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Margin="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="160" Margin="4" BorderBrush="#E0E0E0" BorderThickness="1"
                                CornerRadius="4" Background="White" Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <!-- Label thumbnail placeholder -->
                                <Border Height="80" Background="#F8F8F8" CornerRadius="4,4,0,0">
                                    <TextBlock Text="🏷" FontSize="24"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#CCC"/>
                                </Border>
                                <!-- Label info -->
                                <StackPanel Margin="8,6">
                                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="10" Foreground="#888" Margin="0,2,0,0">
                                        <Run Text="{Binding WidthMm, StringFormat={}{0:F0}}"/>
                                        <Run Text="×"/>
                                        <Run Text="{Binding HeightMm, StringFormat={}{0:F0}}"/>
                                        <Run Text="mm"/>
                                    </TextBlock>
                                </StackPanel>
                                <!-- Actions -->
                                <StackPanel Orientation="Horizontal" Margin="8,0,8,6">
                                    <Button Content="✏️" FontSize="10" Padding="4,2" ToolTip="编辑"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="🖨️" FontSize="10" Padding="4,2" ToolTip="打印"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                    <Button Content="🗑️" FontSize="10" Padding="4,2" ToolTip="删除"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding DataContext.DeleteLabelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="···" FontSize="10" Padding="4,2" ToolTip="更多"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Capacity indicator -->
        <Border Grid.Row="3" Background="#F5F5F5" Padding="12,6" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding CapacityText}" FontSize="11" Foreground="#888" HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</UserControl>
