<UserControl x:Class="CodePrint.Views.Panels.LabelManagementPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CodePrint.ViewModels"
             Background="White">
    <UserControl.DataContext>
        <vm:LabelManagementViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="🍅" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="番茄标签" Foreground="White" FontSize="16" FontWeight="Bold" Margin="8,0,24,0" VerticalAlignment="Center"/>
                    <Button Content="新建标签" Style="{StaticResource TitleBarButton}" FontSize="13" FontWeight="SemiBold"/>
                    <Button Content="模板选择" Style="{StaticResource TitleBarButton}" FontSize="13" FontWeight="SemiBold"/>
                    <Button Content="设置" Style="{StaticResource TitleBarButton}" FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Border Background="#33FFFFFF" CornerRadius="3" Padding="8,3" Margin="4,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CapacityText}" Foreground="White" FontSize="11"/>
                    </Border>
                    <Button Content="← 返回" Style="{StaticResource TitleBarButton}" FontSize="13"
                            Command="{Binding GoBackCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 标签页 + 搜索栏 + 操作栏 -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- 标签页切换: 我的 / 模板库 -->
                <StackPanel Orientation="Horizontal" Margin="24,12,24,0">
                    <TextBlock Text="我的" FontSize="14" FontWeight="SemiBold" Foreground="#333" Cursor="Hand"
                               Padding="0,0,0,8" Margin="0,0,24,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextDecorations">
                                    <Setter.Value>
                                        <TextDecorationCollection>
                                            <TextDecoration Location="Underline" PenOffset="6">
                                                <TextDecoration.Pen>
                                                    <Pen Brush="{StaticResource PrimaryBrush}" Thickness="2"/>
                                                </TextDecoration.Pen>
                                            </TextDecoration>
                                        </TextDecorationCollection>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="模板库" FontSize="14" Foreground="#999" Cursor="Hand" Padding="0,0,0,8"/>
                </StackPanel>

                <!-- 搜索栏 + 操作按钮 -->
                <Grid Margin="24,12,24,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 新建文件夹 -->
                    <Button Grid.Column="0" Padding="10,6" Margin="0,0,16,0" FontSize="12"
                            Background="White" BorderBrush="#FF6D00" BorderThickness="1" Foreground="#FF6D00"
                            Cursor="Hand" Command="{Binding CreateFolderCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="＋" FontSize="12" Foreground="#FF6D00" Margin="0,0,4,0"/>
                            <TextBlock Text="新建文件夹" FontSize="12" Foreground="#FF6D00"/>
                        </StackPanel>
                    </Button>

                    <!-- 搜索框 -->
                    <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0" Padding="8,4" FontSize="12" VerticalContentAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                            <VisualBrush.Visual>
                                                                <TextBlock Text="  请输入标签名称搜索" Foreground="#BBB" FontSize="12" Margin="6,0"/>
                                                            </VisualBrush.Visual>
                                                        </VisualBrush>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBlock Grid.Column="1" Text="🔍" FontSize="14" VerticalAlignment="Center"
                                       Margin="4,0,8,0" Foreground="#999"/>
                        </Grid>
                    </Border>

                    <!-- 排序 -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,8,0">
                        <TextBlock Text="↕ 排序" FontSize="12" VerticalAlignment="Center" Foreground="#666" Margin="0,0,8,0"/>
                    </StackPanel>

                    <!-- 多选 -->
                    <Button Grid.Column="4" Content="多选" FontSize="12" Padding="10,5" Margin="0,0,8,0"
                            Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                            Foreground="#4A90D9"
                            Command="{Binding ToggleMultiSelectCommand}"/>

                    <!-- 批量操作 -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal"
                                Visibility="{Binding IsMultiSelectMode, Converter={StaticResource BoolToVisibility}}">
                        <Button Content="批量打印" FontSize="12" Padding="10,5" Margin="0,0,4,0"
                                Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                                Command="{Binding BatchPrintCommand}"/>
                        <Button Content="批量删除" FontSize="12" Padding="10,5"
                                Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                                Foreground="#E53935"
                                Command="{Binding BatchDeleteCommand}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 主内容区 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧文件夹列表 -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8">
                    <ItemsControl ItemsSource="{Binding Folders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0" Padding="16,10" FontSize="13"
                                        HorizontalContentAlignment="Left" Cursor="Hand"
                                        Command="{Binding DataContext.SelectFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Foreground" Value="#666"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding Name}" FontSize="13"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- 右侧标签卡片网格 -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredLabels}" Margin="16,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="200" Margin="8" BorderBrush="#E0E0E0" BorderThickness="1"
                                    CornerRadius="4" Background="White" Effect="{StaticResource CardShadow}"
                                    Cursor="Hand">
                                <StackPanel>
                                    <!-- 标签缩略图区域 (双击编辑) -->
                                    <Border Height="160" Background="#F8F8F8" CornerRadius="4,4,0,0"
                                            MouseLeftButtonDown="LabelCard_MouseDown">
                                        <Border.Tag>
                                            <Binding Path="Id"/>
                                        </Border.Tag>
                                        <Grid>
                                            <!-- 标签内容缩略图 (有元素时显示) -->
                                            <Viewbox Stretch="Uniform" Margin="8">
                                                <Image Source="{Binding Converter={StaticResource LabelThumbnail}}"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Viewbox>
                                            <!-- 空标签占位符 (无元素时显示) -->
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Elements.Count}" Value="0">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="🏷" FontSize="40" HorizontalAlignment="Center"
                                                           Foreground="#CCC"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12" Foreground="#999"
                                                           HorizontalAlignment="Center" Margin="0,8,0,0"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- 标签信息 -->
                                    <Grid Margin="10,8,10,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 显示模式：双击可编辑名称 -->
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" Foreground="#333"
                                                   VerticalAlignment="Center"
                                                   MouseLeftButtonDown="LabelName_MouseDown"/>
                                        <!-- 编辑模式：输入框 -->
                                        <TextBox FontSize="12" VerticalAlignment="Center"
                                                 Visibility="Collapsed" Padding="0" Margin="0"
                                                 LostFocus="LabelNameEdit_LostFocus"
                                                 KeyDown="LabelNameEdit_KeyDown"/>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                                   FontSize="11" Foreground="#999">
                                            <Run Text="{Binding WidthMm, StringFormat={}{0:F0}}"/>
                                            <Run Text="*"/>
                                            <Run Text="{Binding HeightMm, StringFormat={}{0:F0}}"/>
                                        </TextBlock>
                                    </Grid>

                                    <!-- 操作按钮行 -->
                                    <Grid Margin="6,2,6,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Cursor="Hand" Padding="4,4"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.EditLabelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel>
                                                <TextBlock Text="✏️" FontSize="16" HorizontalAlignment="Center"/>
                                                <TextBlock Text="编辑" FontSize="10" HorizontalAlignment="Center" Foreground="#666"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Grid.Column="1" Cursor="Hand" Padding="4,4"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.PrintLabelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel>
                                                <TextBlock Text="🖨️" FontSize="16" HorizontalAlignment="Center"/>
                                                <TextBlock Text="打印" FontSize="10" HorizontalAlignment="Center" Foreground="#666"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Grid.Column="2" Cursor="Hand" Padding="4,4"
                                                Background="Transparent" BorderThickness="0"
                                                Command="{Binding DataContext.DeleteLabelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel>
                                                <TextBlock Text="🗑️" FontSize="16" HorizontalAlignment="Center"/>
                                                <TextBlock Text="删除" FontSize="10" HorizontalAlignment="Center" Foreground="#666"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Grid.Column="3" Content="···" Cursor="Hand" Padding="8,4"
                                                Background="Transparent" BorderThickness="0" FontSize="14" Foreground="#666"
                                                VerticalAlignment="Center" Click="MoreButton_Click"
                                                Tag="{Binding}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 空状态提示 -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilteredLabels.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Foreground="#CCC"/>
                <TextBlock Text="暂无标签" FontSize="16" Foreground="#AAA" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                <TextBlock Text="点击「新建标签」开始创建" FontSize="12" Foreground="#CCC" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
