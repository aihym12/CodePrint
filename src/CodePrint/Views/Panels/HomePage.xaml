<UserControl x:Class="CodePrint.Views.Panels.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CodePrint.ViewModels"
             Background="White">

    <UserControl.DataContext>
        <vm:HomeViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Nav Items -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="🍅" FontSize="20" VerticalAlignment="Center"/>
                    <TextBlock Text="番茄标签" Foreground="White" FontSize="16" FontWeight="Bold" Margin="8,0,24,0" VerticalAlignment="Center"/>

                    <Button Content="新建标签" Style="{StaticResource TitleBarButton}" FontSize="13" FontWeight="SemiBold"
                            Command="{Binding SelectNavItemCommand}" CommandParameter="新建标签"/>
                    <Button Content="模板选择" Style="{StaticResource TitleBarButton}" FontSize="13"
                            Command="{Binding OpenTemplateLibraryCommand}"/>
                    <Button Content="设置" Style="{StaticResource TitleBarButton}" FontSize="13" Click="Settings_Click"/>
                    <Border Background="#FFFFFF" CornerRadius="2" Padding="3,1" Margin="2,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="new" Foreground="{StaticResource PrimaryBrush}" FontSize="9" FontWeight="Bold"/>
                    </Border>
                    <Button Content="视频教程" Style="{StaticResource TitleBarButton}" FontSize="13" Margin="8,0,0,0"/>
                    <Button Content="推广有奖" Style="{StaticResource TitleBarButton}" FontSize="13"/>
                </StackPanel>

                <!-- Right side info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="APP" Style="{StaticResource TitleBarButton}" FontSize="12"/>
                    <Button Content="意见反馈" Style="{StaticResource TitleBarButton}" FontSize="12"/>
                    <Button Content="联系客服" Style="{StaticResource TitleBarButton}" FontSize="12"/>
                    <Border Background="#33FFFFFF" CornerRadius="3" Padding="8,3" Margin="4,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TemplateCapacityText}" Foreground="White" FontSize="11"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentUser.MaskedPhone}" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sub-header line -->
        <Border Grid.Row="1" Background="#FBE9E7" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <TextBlock Text="选择一种方式开始" Foreground="#333" FontSize="13" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="24,0"/>
        </Border>

        <!-- Main Content: Four Entry Cards -->
        <Grid Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: New Blank Label -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="8" Cursor="Hand" Effect="{StaticResource CardShadow}"
                    MouseLeftButtonUp="NewBlankLabel_Click">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FFF3E0" CornerRadius="50" Width="100" Height="100"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="+" FontSize="48" Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Light"/>
                    </Border>

                    <TextBlock Grid.Row="1" Text="新建空白标签模板" FontSize="15" FontWeight="SemiBold"
                               Foreground="#333" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>

            <!-- Card 2: PDF Crop & Print -->
            <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="8" Cursor="Hand" Effect="{StaticResource CardShadow}"
                    MouseLeftButtonUp="PdfCropPrint_Click">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#E3F2FD" CornerRadius="50" Width="100" Height="100"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📄" FontSize="44"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Row="1" Text="PDF剪裁与打印" FontSize="15" FontWeight="SemiBold"
                               Foreground="#333" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>

            <!-- Card 3: Photo Print -->
            <Border Grid.Column="4" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="8" Cursor="Hand" Effect="{StaticResource CardShadow}"
                    MouseLeftButtonUp="PhotoPrint_Click">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#E8F5E9" CornerRadius="50" Width="100" Height="100"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🖼" FontSize="44"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Row="1" Text="照片打印" FontSize="15" FontWeight="SemiBold"
                               Foreground="#333" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
            <!-- Card 4: Import Photo as Template -->
            <Border Grid.Column="6" Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                    CornerRadius="8" Cursor="Hand" Effect="{StaticResource CardShadow}"
                    MouseLeftButtonUp="ImportImageTemplate_Click">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#EDE7F6" CornerRadius="50" Width="100" Height="100"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📷" FontSize="44"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Row="1" Text="导入照片生成模板" FontSize="15" FontWeight="SemiBold"
                               Foreground="#333" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
