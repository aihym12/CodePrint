<Window x:Class="CodePrint.Views.Dialogs.PdfPrintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="打印" Width="440" Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="White">

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Printer selection -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="选打印机：" VerticalAlignment="Center" FontSize="13"/>
            <ComboBox x:Name="PrinterCombo" Grid.Column="1" FontSize="13" Padding="6,4"
                      ItemsSource="{Binding Printers}" SelectedItem="{Binding SelectedPrinter}"/>
            <TextBlock Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                <Hyperlink x:Name="AddCloudPrinterLink" Click="AddCloudPrinter_Click"
                           Foreground="#4A90D9" TextDecorations="None" FontSize="12">
                    添加云打印机
                </Hyperlink>
            </TextBlock>
        </Grid>

        <!-- Page range -->
        <Grid Grid.Row="1" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="页码范围：" VerticalAlignment="Center" FontSize="13"/>
            <TextBox Grid.Column="1" Text="{Binding PageFrom, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="6,4" HorizontalContentAlignment="Center"/>
            <TextBlock Grid.Column="2" Text=" - " VerticalAlignment="Center" FontSize="13" Margin="8,0"/>
            <TextBox Grid.Column="3" Text="{Binding PageTo, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="6,4" HorizontalContentAlignment="Center"/>
        </Grid>

        <!-- Copies -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="输出份数：" VerticalAlignment="Center" FontSize="13"/>
            <TextBox Grid.Column="1" Text="{Binding Copies, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="13" Padding="6,4" HorizontalContentAlignment="Center"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="确 认" Width="80" Padding="8,8" FontSize="13" Margin="0,0,16,0"
                    Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                    Click="Confirm_Click"/>
            <Button Content="取 消" Width="80" Padding="8,8" FontSize="13"
                    Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                    IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
