<Window x:Class="CodePrint.Views.Dialogs.NewLabelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建空白标签" Width="400" Height="340"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="设置标签参数" FontSize="16" FontWeight="SemiBold" Foreground="#333"/>

        <!-- Label Name -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="标签名称：" VerticalAlignment="Center" FontSize="13"/>
            <TextBox x:Name="NameTextBox" Grid.Column="1" Padding="6,4" FontSize="13"/>
        </Grid>

        <!-- Width -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="标签宽度：" VerticalAlignment="Center" FontSize="13"/>
            <TextBox x:Name="WidthTextBox" Grid.Column="1" Padding="6,4" FontSize="13" Text="50"/>
            <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" FontSize="12" Foreground="#666" Margin="6,0,0,0"/>
        </Grid>

        <!-- Height -->
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="标签高度：" VerticalAlignment="Center" FontSize="13"/>
            <TextBox x:Name="HeightTextBox" Grid.Column="1" Padding="6,4" FontSize="13" Text="30"/>
            <TextBlock Grid.Column="2" Text="mm" VerticalAlignment="Center" FontSize="12" Foreground="#666" Margin="6,0,0,0"/>
        </Grid>

        <!-- Orientation -->
        <Grid Grid.Row="5" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="打印方向：" VerticalAlignment="Center" FontSize="13"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <RadioButton x:Name="LandscapeRadio" Content="横向" IsChecked="True" Margin="0,0,16,0" FontSize="13" VerticalAlignment="Center"/>
                <RadioButton x:Name="PortraitRadio" Content="纵向" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Padding="16,6" FontSize="13" IsCancel="True" Margin="0,0,12,0"
                    Click="Cancel_Click"/>
            <Button Content="确定" Style="{StaticResource PrimaryButton}" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
