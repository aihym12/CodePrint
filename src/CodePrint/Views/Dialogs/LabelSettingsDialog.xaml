<Window x:Class="CodePrint.Views.Dialogs.LabelSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CodePrint.ViewModels"
        Title="标签设置" Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Window.DataContext>
        <vm:LabelSettingsViewModel/>
    </Window.DataContext>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="纸张尺寸" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding WidthMm}" Padding="4" Margin="0,0,4,0"/>
                    <TextBlock Grid.Column="1" Text="×" VerticalAlignment="Center" Margin="4"/>
                    <TextBox Grid.Column="2" Text="{Binding HeightMm}" Padding="4" Margin="4,0,0,0"/>
                    <TextBlock Grid.Column="3" Text="mm" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </Grid>

                <TextBlock Text="打印方向" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="纵向" IsChecked="True" Margin="0,0,16,0"/>
                    <RadioButton Content="横向"/>
                </StackPanel>

                <TextBlock Text="间距设置" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,4,0">
                        <TextBlock Text="行间距 (mm)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding RowSpacing}" Padding="4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                        <TextBlock Text="列间距 (mm)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding ColumnSpacing}" Padding="4"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="边距设置" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Margin="0,0,4,4">
                        <TextBlock Text="上 (mm)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding MarginTop}" Padding="4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4,0,0,4">
                        <TextBlock Text="下 (mm)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding MarginBottom}" Padding="4"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Margin="0,0,4,4">
                        <TextBlock Text="左 (mm)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding MarginLeft}" Padding="4"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,0,4">
                        <TextBlock Text="右 (mm)" FontSize="11" Foreground="#888" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding MarginRight}" Padding="4"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="每行数量" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,8"/>
                <TextBox Text="{Binding ColumnsPerRow}" Padding="4" Width="80" HorizontalAlignment="Left"/>

                <TextBlock Text="背景颜色" FontSize="13" FontWeight="SemiBold" Margin="0,16,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <Border Width="32" Height="32" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4"
                            Background="{Binding BackgroundColor, Converter={StaticResource ColorToBrush}}"/>
                    <TextBox Text="{Binding BackgroundColor}" Padding="4" Margin="8,0,0,0" Width="100" VerticalContentAlignment="Center"/>
                </StackPanel>

                <CheckBox Content="等比例缩放画布内容" IsChecked="{Binding ScaleElements}" Margin="0,16,0,0"
                          ToolTip="更改画布尺寸时，自动等比例缩放所有元素的位置、大小和字号"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="取消" Width="80" Padding="8,6" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="确定" Width="80" Padding="8,6" Style="{StaticResource PrimaryButton}" IsDefault="True" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
