<Window x:Class="CodePrint.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CodePrint.ViewModels"
        xmlns:panels="clr-namespace:CodePrint.Views.Panels"
        Title="番茄标签" Width="1400" Height="900"
        MinWidth="1280" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid>
        <!-- Home Page (visible by default) -->
        <panels:HomePage x:Name="HomePageView" Visibility="Visible"/>

        <!-- Designer View (hidden until user creates/opens a label) -->
        <Grid x:Name="DesignerView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <TextBlock Text="🍅" FontSize="20" VerticalAlignment="Center"/>
                        <TextBlock Text="番茄标签" Foreground="White" FontSize="16" FontWeight="Bold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="{Binding DocumentTitle}" Foreground="White" FontSize="13"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="🏠 主页" Style="{StaticResource TitleBarButton}" Margin="0,0,8,0" Click="BackToHome_Click"/>
                        <Button Content="联系客服" Style="{StaticResource TitleBarButton}" Margin="0,0,8,0"/>
                        <Button Content="✕" Style="{StaticResource TitleBarButton}" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Toolbar -->
            <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <Button Content="💾 保存" Style="{StaticResource ToolbarButton}" Command="{Binding SaveCommand}"/>
                        <Button Content="📋 复制" Style="{StaticResource ToolbarButton}" Command="{Binding CopySelectedCommand}"/>
                        <Button Content="📌 粘贴" Style="{StaticResource ToolbarButton}" Command="{Binding PasteCommand}"/>
                        <Button Content="🗑 删除" Style="{StaticResource ToolbarButton}" Command="{Binding DeleteSelectedCommand}"/>
                        <Separator Style="{StaticResource ToolbarSeparator}"/>
                        <Button Content="↩ 撤销" Style="{StaticResource ToolbarButton}" Command="{Binding UndoCommand}"/>
                        <Button Content="↪ 恢复" Style="{StaticResource ToolbarButton}" Command="{Binding RedoCommand}"/>
                        <Button Content="⬜ 全选" Style="{StaticResource ToolbarButton}" Command="{Binding SelectAllCommand}"/>
                        <Button Content="🔄 旋转" Style="{StaticResource ToolbarButton}" Command="{Binding RotateSelectedCommand}"/>
                        <Separator Style="{StaticResource ToolbarSeparator}"/>
                        <Button Content="📐 标签设置" Style="{StaticResource ToolbarButton}" Click="LabelSettings_Click"/>
                        <Button Content="📑 图层" Style="{StaticResource ToolbarButton}" Command="{Binding ToggleLayerPanelCommand}"/>
                        <Separator Style="{StaticResource ToolbarSeparator}"/>
                        <Button Content="⫷" Style="{StaticResource ToolbarButton}" ToolTip="左对齐" Command="{Binding AlignLeftCommand}"/>
                        <Button Content="⫿" Style="{StaticResource ToolbarButton}" ToolTip="水平居中" Command="{Binding AlignCenterHCommand}"/>
                        <Button Content="⫸" Style="{StaticResource ToolbarButton}" ToolTip="右对齐" Command="{Binding AlignRightCommand}"/>
                        <Button Content="⊤" Style="{StaticResource ToolbarButton}" ToolTip="顶对齐" Command="{Binding AlignTopCommand}"/>
                        <Button Content="⊥" Style="{StaticResource ToolbarButton}" ToolTip="底对齐" Command="{Binding AlignBottomCommand}"/>
                        <Button Content="⊟" Style="{StaticResource ToolbarButton}" ToolTip="垂直居中" Command="{Binding AlignCenterVCommand}"/>
                        <Separator Style="{StaticResource ToolbarSeparator}"/>
                        <Button Content="−" Style="{StaticResource ToolbarButton}" Width="28" Command="{Binding ZoomOutCommand}"/>
                        <TextBlock Text="{Binding ZoomPercentage}" VerticalAlignment="Center" MinWidth="45" TextAlignment="Center" FontSize="12"/>
                        <Button Content="+" Style="{StaticResource ToolbarButton}" Width="28" Command="{Binding ZoomInCommand}"/>
                        <Button Content="⊡ 适应" Style="{StaticResource ToolbarButton}" Command="{Binding FitToWindowCommand}" Margin="4,0,0,0"/>
                        <Separator Style="{StaticResource ToolbarSeparator}"/>
                        <Button Content="🔒 加锁" Style="{StaticResource ToolbarButton}" Command="{Binding ToggleLockCommand}"/>
                        <Separator Style="{StaticResource ToolbarSeparator}"/>
                        <Button Content="💾 另存为" Style="{StaticResource ToolbarButton}" Click="SaveAs_Click"/>
                        <Button Content="🔗 分享" Style="{StaticResource ToolbarButton}"/>
                        <Button Content="👁 预览" Style="{StaticResource ToolbarButton}" Click="Preview_Click"/>
                        <Button Content="🖨 打印" Style="{StaticResource ToolbarButton}" Click="Print_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Font Formatting Bar -->
            <Border Grid.Row="2" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                        <ComboBox x:Name="FontFamilyCombo" Width="140" Margin="0,0,4,0" ToolTip="字体" SelectedIndex="0"
                                  SelectionChanged="FontFamilyCombo_SelectionChanged">
                            <ComboBoxItem Content="微软雅黑"/>
                            <ComboBoxItem Content="宋体"/>
                            <ComboBoxItem Content="黑体"/>
                            <ComboBoxItem Content="楷体"/>
                            <ComboBoxItem Content="仿宋"/>
                            <ComboBoxItem Content="Arial"/>
                            <ComboBoxItem Content="Times New Roman"/>
                        </ComboBox>
                        <ComboBox x:Name="FontSizeCombo" Width="60" Margin="0,0,4,0" ToolTip="字号" SelectedIndex="3" IsEditable="True"
                                  SelectionChanged="FontSizeCombo_SelectionChanged"
                                  LostFocus="FontSizeCombo_LostFocus"
                                  KeyDown="FontSizeCombo_KeyDown">
                            <ComboBoxItem Content="8"/>
                            <ComboBoxItem Content="9"/>
                            <ComboBoxItem Content="10"/>
                            <ComboBoxItem Content="12"/>
                            <ComboBoxItem Content="14"/>
                            <ComboBoxItem Content="16"/>
                            <ComboBoxItem Content="18"/>
                            <ComboBoxItem Content="20"/>
                            <ComboBoxItem Content="24"/>
                            <ComboBoxItem Content="28"/>
                            <ComboBoxItem Content="36"/>
                            <ComboBoxItem Content="48"/>
                            <ComboBoxItem Content="72"/>
                        </ComboBox>
                        <Separator Style="{StaticResource ToolbarSeparator}"/>
                        <TextBlock Text="字间距" VerticalAlignment="Center" Margin="4,0" FontSize="11"/>
                        <TextBox x:Name="LetterSpacingBox" Width="40" Text="0" VerticalContentAlignment="Center" Margin="0,0,4,0"
                                 LostFocus="LetterSpacingBox_LostFocus" KeyDown="LetterSpacingBox_KeyDown"/>
                        <TextBlock Text="行间距" VerticalAlignment="Center" Margin="4,0" FontSize="11"/>
                        <TextBox x:Name="LineSpacingBox" Width="40" Text="1.2" VerticalContentAlignment="Center" Margin="0,0,4,0"
                                 LostFocus="LineSpacingBox_LostFocus" KeyDown="LineSpacingBox_KeyDown"/>
                        <Separator Style="{StaticResource ToolbarSeparator}"/>
                        <Button x:Name="BoldButton" Content="B" Style="{StaticResource FormatButton}" FontWeight="Bold" ToolTip="粗体" Click="BoldButton_Click"/>
                        <Button x:Name="ItalicButton" Content="I" Style="{StaticResource FormatButton}" FontStyle="Italic" ToolTip="斜体" Click="ItalicButton_Click"/>
                        <Button x:Name="UnderlineButton" Content="U" Style="{StaticResource FormatButton}" ToolTip="下划线" Click="UnderlineButton_Click"/>
                        <Button x:Name="StrikethroughButton" Content="S" Style="{StaticResource FormatButton}" ToolTip="删除线" Click="StrikethroughButton_Click"/>
                        <Separator Style="{StaticResource ToolbarSeparator}"/>
                        <Button Content="≡⫷" Style="{StaticResource FormatButton}" ToolTip="左对齐"/>
                        <Button Content="≡⊟" Style="{StaticResource FormatButton}" ToolTip="居中"/>
                        <Button Content="≡⫸" Style="{StaticResource FormatButton}" ToolTip="右对齐"/>
                        <Button Content="≡≡" Style="{StaticResource FormatButton}" ToolTip="两端对齐"/>
                        <Separator Style="{StaticResource ToolbarSeparator}"/>
                        <TextBlock Text="x:" VerticalAlignment="Center" Margin="4,0,2,0" FontSize="11"/>
                        <TextBox Width="50" VerticalContentAlignment="Center" FontSize="11">
                            <TextBox.Text>
                                <Binding Path="SelectedElement.X" StringFormat="F1" UpdateSourceTrigger="PropertyChanged" FallbackValue=""/>
                            </TextBox.Text>
                        </TextBox>
                        <TextBlock Text="y:" VerticalAlignment="Center" Margin="4,0,2,0" FontSize="11"/>
                        <TextBox Width="50" VerticalContentAlignment="Center" FontSize="11">
                            <TextBox.Text>
                                <Binding Path="SelectedElement.Y" StringFormat="F1" UpdateSourceTrigger="PropertyChanged" FallbackValue=""/>
                            </TextBox.Text>
                        </TextBox>
                        <TextBlock Text="w:" VerticalAlignment="Center" Margin="4,0,2,0" FontSize="11"/>
                        <TextBox Width="50" VerticalContentAlignment="Center" FontSize="11">
                            <TextBox.Text>
                                <Binding Path="SelectedElement.Width" StringFormat="F1" UpdateSourceTrigger="PropertyChanged" FallbackValue=""/>
                            </TextBox.Text>
                        </TextBox>
                        <TextBlock Text="h:" VerticalAlignment="Center" Margin="4,0,2,0" FontSize="11"/>
                        <TextBox Width="50" VerticalContentAlignment="Center" FontSize="11">
                            <TextBox.Text>
                                <Binding Path="SelectedElement.Height" StringFormat="F1" UpdateSourceTrigger="PropertyChanged" FallbackValue=""/>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel -->
                <panels:ElementPanel Grid.Column="0"/>

                <!-- Center Canvas -->
                <Grid Grid.Column="1">
                    <panels:CanvasPanel DataContext="{Binding}"/>

                    <!-- Layer Panel (floating overlay, toggled by 图层 button) -->
                    <panels:LayerPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                                       Width="200" MaxHeight="400" Margin="0,8,8,0"
                                       Visibility="{Binding IsLayerPanelVisible, Converter={StaticResource BoolToVisibility}}"/>
                </Grid>

                <!-- Right Panel -->
                <panels:PropertyPanel Grid.Column="2"/>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="4" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="11" Foreground="#666"/>
                    <TextBlock Grid.Column="1" Text="最新版本 v1.0" VerticalAlignment="Center" FontSize="11" Foreground="#666" Margin="0,0,20,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding CurrentUser.MaskedPhone}" VerticalAlignment="Center" FontSize="11" Foreground="#666"/>
                </Grid>
            </Border>
        </Grid>

        <!-- PDF Crop View (hidden until user selects it) -->
        <panels:PdfCropView x:Name="PdfCropViewPanel" Visibility="Collapsed"/>

        <!-- Photo Print View (hidden until user selects it) -->
        <panels:PhotoPrintView x:Name="PhotoPrintViewPanel" Visibility="Collapsed"/>

        <!-- Label Management View (hidden until user selects 模板选择) -->
        <panels:LabelManagementPanel x:Name="LabelManagementViewPanel" Visibility="Collapsed"/>
    </Grid>
</Window>
